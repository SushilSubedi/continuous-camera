{
  "name": "@continuous-camera/core",
  "version": "0.2.0",
  "description": "Framework-agnostic continuous camera API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SushilSubedi/continuous-camera.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/SushilSubedi/continuous-camera/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/SushilSubedi/continuous-camera/issues"
  },
  "author": "Sushil Subedi",
  "keywords": ["camera", "webcam", "mediastream", "getUserMedia", "capture", "video"],
  "license": "MIT",
  "sideEffects": false
}
