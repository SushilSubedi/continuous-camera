{
  "name": "@continuous-camera/react",
  "version": "0.1.0",
  "description": "React hooks and components for continuous camera",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@continuous-camera/core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "jsdom": "^29.0.1",
    "react": "^18.3.0",
    "react-dom": "18",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SushilSubedi/continuous-camera.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/SushilSubedi/continuous-camera/tree/main/packages/react",
  "bugs": {
    "url": "https://github.com/SushilSubedi/continuous-camera/issues"
  },
  "author": "Sushil Subedi",
  "keywords": ["camera", "react", "hooks", "webcam", "getUserMedia", "nextjs", "video"],
  "license": "MIT",
  "sideEffects": false
}
